
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet League Security Rules
     */

    // --- REGRA MESTRE: Jardel tem acesso total ---
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == "TquLV2ai1yRgfWPJHZGrHKifgc72" || 
        request.auth.token.email == "jardel@alphabet.com"
      );
    }

    // Regras para perfis de usuários
    match /users/{userId} {
      // Qualquer usuário autenticado pode ler os perfis (necessário para o Ranking e Tabelas)
      allow read: if request.auth != null;
      // Apenas o próprio usuário pode criar ou atualizar seu perfil
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para rodadas e apostas
    match /rounds/{roundId} {
      // Todos logados podem ver os metadados da rodada (nome, status oculto, etc)
      allow read: if request.auth != null;
      
      match /bets/{betId} {
        // Permitimos que todos os usuários autenticados listem as apostas da rodada.
        // O controle de visibilidade dos placares (isScoresHidden) é gerenciado na UI,
        // permitindo que o app mostre o status de aposta de todos sem expor os dados sensíveis.
        allow read: if request.auth != null;
        
        // Apenas o dono da aposta pode criar ou modificar seu palpite
        allow write: if request.auth != null && betId.startsWith(request.auth.uid);
      }
    }

    // Verificação de privilégios administrativos
    match /roles_admin/{userId} {
      allow get: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.email == "jardel@alphabet.com";
    }

    // Configurações globais do app
    match /app_settings/{docId} {
      allow read: if request.auth != null;
      // Escrita permitida apenas pelo admin (via regra mestre)
    }
  }
}
