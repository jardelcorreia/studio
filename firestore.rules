rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet League Security Rules
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Atualizado para permitir Admin baseado no documento físico OU no nome do token (para o protótipo)
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.name == "Jardel"
      );
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;

      match /bets/{betId} {
        allow get, list: if isOwner(userId) || (resource.data.isScoresHidden == false);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      match /overall_stats {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isAdmin();
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      // Permite que o Jardel crie seu próprio registro de admin
      allow create: if isSignedIn() && (request.auth.token.name == "Jardel" && userId == request.auth.uid);
      allow list, update, delete: if false; 
    }

    match /app_settings/league_config {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /rounds/{roundId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /matches/{matchId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /player_scores/{userId} {
        allow get, list: if isOwner(userId) || (resource.data.isScoresHidden == false);
        allow create, update, delete: if isAdmin();
      }
    }
  }
}