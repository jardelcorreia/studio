rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet League Security Rules
     */

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin: UID direto (Jardel), E-mail ou registro na coleção roles_admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "TquLV2ai1yRgfWPJHZGrHKifgc72" || 
        request.auth.token.email == "jardel@alphabet.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Regras Globais e de Grupo ---
    
    // Permite que admins listem qualquer documento em qualquer lugar
    // Isso resolve o erro de 'list' no caminho raiz '/'
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Regras específicas para consultas de grupo (Collection Group)
    match /{path=**}/bets/{betId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isOwner(resource.data.userId) || 
        (resource.data.isScoresHidden == false)
      );
    }

    match /{path=**}/player_scores/{userId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isOwner(userId) || 
        (resource.data.isScoresHidden == false)
      );
    }

    // --- Regras de Caminhos Específicos ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /bets/{betId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /overall_stats {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isAdmin();
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.token.email == "jardel@alphabet.com" && userId == request.auth.uid
      );
      allow list, update, delete: if false; 
    }

    match /app_settings/{docId} {
      allow get: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /rounds/{roundId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /matches/{matchId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /player_scores/{userId} {
        allow get, list: if isOwner(userId) || isAdmin() || resource.data.isScoresHidden == false;
        allow create, update, delete: if isAdmin();
      }
    }
  }
}