rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet 2026 Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a hybrid security model. User-specific data (profiles and bets) follows a 
     * strict ownership pattern, while championship metadata, rounds, and leaderboard statistics are 
     * globally readable by authenticated users but restricted to administrators for modifications.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Private player profiles.
     * - /users/{userId}/championships/{championshipId}/bets/{matchId}: Personal betting predictions.
     * - /championships/{championshipId}: Public championship configuration and state.
     * - /championships/...: Subcollections for rounds, matches, and aggregated scoring statistics.
     * - /roles_admin/{userId}: Sentinel collection where the existence of a document grants admin privileges.
     *
     * KEY SECURITY DECISIONS:
     * 1. Admin Authorization: Admin status is determined via a fast lookup in the `/roles_admin` collection.
     * 2. Read Visibility: Most championship data is public (get/list) to all authenticated users to power the leaderboard.
     * 3. Bet Privacy: Bets are private to the owner and admins unless the `isScoresVisible` flag (denormalized 
     *    from championship settings) is set to true.
     * 4. Relational Integrity: On creation of user-scoped documents, we enforce that the internal 
     *    `playerId` or `id` matches the authenticated user's UID and the document path.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user owns the existing document and it exists. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Checks if the user has an admin role marker. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description User profile data for players.
     * @path /users/{userId}
     * @allow (get, list, update) if isOwner(userId); (get, list) if isAdmin();
     * @deny (create) if auth.uid != userId; (delete) if not admin;
     * @principle Restricts access to a user's own profile and enforces ID consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
    }

    /**
     * @description Individual betting predictions for matches.
     * @path /users/{userId}/championships/{championshipId}/bets/{matchId}
     * @allow (get, list) if isOwner(userId) || resource.data.isScoresVisible == true;
     * @deny (write) if auth.uid != userId;
     * @principle Enforces document ownership for writes and conditional visibility for reads.
     */
    match /users/{userId}/championships/{championshipId}/bets/{matchId} {
      allow get, list: if isOwner(userId) || isAdmin() || (resource != null && resource.data.isScoresVisible == true);
      allow create: if isOwner(userId) && request.resource.data.playerId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.playerId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Championship configuration and global state.
     * @path /championships/{championshipId}
     * @allow (get, list) if isSignedIn(); (write) if isAdmin();
     * @deny (write) if not admin;
     * @principle Public read access for participants, restricted write access for admins.
     */
    match /championships/{championshipId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
      
      /**
       * @description Details for each betting round.
       * @path /championships/{championshipId}/rounds/{roundId}
       */
      match /rounds/{roundId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();

        /**
         * @description Individual football matches within a round.
         * @path /championships/{championshipId}/rounds/{roundId}/matches/{matchId}
         */
        match /matches/{matchId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isAdmin();
        }
      }

      /**
       * @description Calculated points for a player in a specific round.
       * @path /championships/{championshipId}/playerRoundScores/{docId}
       */
      match /playerRoundScores/{docId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      /**
       * @description Cumulative championship statistics for the leaderboard.
       * @path /championships/{championshipId}/overallPlayerChampionshipStats/{playerId}
       */
      match /overallPlayerChampionshipStats/{playerId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Database Access Control (DBAC) marker for administrators.
     * @path /roles_admin/{userId}
     * @allow (get) if isSignedIn(); (list, write) if isAdmin();
     * @deny (write) if not already admin;
     * @principle Secures the administrative role assignment process.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

  }
}