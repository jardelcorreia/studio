rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet League Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a hybrid security model tailored for a competitive sports league. 
     * It combines strict User-Ownership for personal data (bets, profiles) with Role-Based Access 
     * Control (RBAC) via a dedicated administrators collection.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Private user profiles and nested personal data.
     * - /rounds/{roundId}: Global league data including match schedules and player scores.
     * - /roles_admin/{userId}: A lookup collection where the presence of a UID grants admin rights.
     * - /app_settings: Global configuration singletons.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Critical fields like 'isScoresHidden' are denormalized 
     *    directly into 'PlayerBet' and 'RoundPlayerScore' documents. This allows the rules 
     *    to evaluate visibility without performing expensive and slow 'get()' lookups 
     *    to a parent Round document.
     * 2. Structural Segregation: Personal predictions are kept in user-specific paths, while 
     *    public league data is kept in top-level collections to simplify 'list' operations.
     * 3. Prototyping Flexibility: These rules strictly enforce "Who" can access data (Authorization) 
     *    but remain flexible on "What" the data looks like (Schema), allowing for rapid 
     *    iteration of the data model.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Users can create/manage their own profile.
     * @path /users/{userId}
     * @allow (create) If the authenticated UID matches the document ID.
     * @deny (read) If the requester is not the owner or an admin.
     * @principle Ownership and Self-Creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all users
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;

      /**
       * @description Individual score predictions for matches.
       * @path /users/{userId}/bets/{betId}
       * @allow (get) If owner, or if the round's scores are no longer hidden.
       * @principle Denormalization for Authorization (isScoresHidden field).
       */
      match /bets/{betId} {
        allow get, list: if isOwner(userId) || (resource.data.isScoresHidden == false);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Singleton document for cumulative player statistics.
       * @path /users/{userId}/overall_stats
       * @allow (get) If owner or admin.
       * @principle Restricted access to sensitive performance data.
       */
      match /overall_stats {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isAdmin(); // Stats managed by system/admin
      }
    }

    /**
     * @description Database-Backed Access Control (DBAC) for admin roles.
     * @path /roles_admin/{userId}
     * @allow (get) Any signed-in user to verify admin status.
     * @deny (write) Any client-side modification.
     * @principle Role-Based Access Control.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false; 
    }

    /**
     * @description Global settings for the league.
     * @path /app_settings/league_config
     * @allow (read) Any signed-in user.
     * @allow (write) Only administrators.
     * @principle Public Read with Admin-Only Writes.
     */
    match /app_settings/league_config {
      allow get: if isSignedIn();
      allow list: if false; // Singleton document
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global information about match rounds.
     * @path /rounds/{roundId}
     * @allow (read) All authenticated users.
     * @allow (write) Only administrators.
     * @principle Public Read with Admin-Only Writes.
     */
    match /rounds/{roundId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      /**
       * @description Individual matches within a round.
       * @path /rounds/{roundId}/matches/{matchId}
       * @allow (read) All authenticated users.
       * @principle Hierarchical data inheritance.
       */
      match /matches/{matchId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      /**
       * @description Calculated points for each player in this round.
       * @path /rounds/{roundId}/player_scores/{userId}
       * @allow (get) If owner or if scores are unhidden.
       * @principle Denormalization for Authorization.
       */
      match /player_scores/{userId} {
        allow get, list: if isOwner(userId) || (resource.data.isScoresHidden == false);
        allow create, update, delete: if isAdmin();
      }
    }
  }
}

/**
 * CRITICAL IMPLEMENTATION NOTES:
 * 
 * 1. The 'isScoresHidden' field must be kept in sync: 
 *    When a Round is updated to hide/show scores, all associated 
 *    'PlayerBet' and 'RoundPlayerScore' documents must be updated 
 *    with the same boolean value to maintain security integrity.
 * 
 * 2. 'PlayerBet' Relational Integrity:
 *    The rules enforce that 'userId' in the document data matches 
 *    the path and the authenticated user during creation.
 * 
 * 3. Prototyping Mode: 
 *    These rules do not check for specific field types (e.g., 'totalPoints is int') 
 *    to allow developers to change the schema without breaking security rules.
 */

// Generated with expertise by Firebase Security Rules Architect.