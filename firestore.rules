
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet League Security Rules
     */

    // Função auxiliar para verificar se o usuário é o Administrador (Jardel)
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "TquLV2ai1yRgfWPJHZGrHKifgc72" || 
        request.auth.token.email == "jardel@alphabet.com"
      );
    }

    // Regras para perfis de usuários
    match /users/{userId} {
      allow get, list: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para rodadas e suas subcoleções
    match /rounds/{roundId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      // Regras para apostas (subcoleção)
      match /bets/{betId} {
        allow read: if request.auth != null;
        
        // Permite criar se o userId no dado enviado for o do próprio usuário
        allow create: if request.auth != null && (
          isAdmin() || 
          request.resource.data.userId == request.auth.uid
        );
        
        // Permite atualizar se o usuário for o dono da aposta ou admin
        allow update: if request.auth != null && (
          isAdmin() || 
          (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid)
        );
        
        // Permite deletar se o usuário for o dono da aposta ou admin
        allow delete: if request.auth != null && (
          isAdmin() || 
          resource.data.userId == request.auth.uid
        );
      }
    }

    // Verificação de privilégios administrativos
    match /roles_admin/{userId} {
      allow get: if request.auth != null;
      allow create: if isAdmin();
    }

    // Configurações globais do app
    match /app_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Regra mestre para outros documentos (por segurança)
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
