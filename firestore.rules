rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet League Security Rules
     */

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin: Verificação direta por UID ou E-mail para máxima performance e confiabilidade
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "TquLV2ai1yRgfWPJHZGrHKifgc72" || 
        request.auth.token.email == "jardel@alphabet.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRA MESTRE (ADMIN) ---
    // Administradores têm permissão total em qualquer documento ou consulta (incluindo Collection Groups)
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Regras de Collection Group (Para usuários comuns) ---
    // Essencial para a consulta de palpites de todos os jogadores na tabela
    
    match /{path=**}/bets/{betId} {
      // Usuários comuns podem ver palpites se forem donos ou se a rodada não estiver oculta
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        (resource.data.isScoresHidden == false)
      );
    }

    match /{path=**}/player_scores/{userId} {
      allow read: if isSignedIn() && (
        isOwner(userId) || 
        (resource.data.isScoresHidden == false)
      );
    }

    // --- Regras de Caminhos Específicos (Para usuários comuns) ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      match /bets/{betId} {
        allow read, write: if isOwner(userId);
      }

      match /overall_stats {
        allow get, list: if isOwner(userId);
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.token.email == "jardel@alphabet.com" && userId == request.auth.uid
      );
    }

    match /app_settings/{docId} {
      allow get: if isSignedIn();
    }

    match /rounds/{roundId} {
      allow get, list: if isSignedIn();

      match /matches/{matchId} {
        allow get, list: if isSignedIn();
      }

      match /player_scores/{userId} {
        allow get, list: if isOwner(userId) || resource.data.isScoresHidden == false;
      }
    }
  }
}