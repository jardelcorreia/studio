
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet League Security Rules
     */

    // Função auxiliar para verificar se o usuário é o Administrador (Jardel)
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "TquLV2ai1yRgfWPJHZGrHKifgc72" || 
        request.auth.token.email == "jardel@alphabet.com"
      );
    }

    // Regras para perfis de usuários
    match /users/{userId} {
      allow get, list: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para rodadas (metadados)
    match /rounds/{roundId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      // Regras para apostas (subcoleção)
      match /bets/{betId} {
        allow read: if request.auth != null;
        // Permite escrita se for o admin ou se o ID da aposta começar com o UID do usuário
        allow create, update: if request.auth != null && (
          isAdmin() || 
          betId.startsWith(request.auth.uid)
        );
        allow delete: if isAdmin();
      }
    }

    // Verificação de privilégios administrativos
    match /roles_admin/{userId} {
      allow get: if request.auth != null;
      allow create: if isAdmin();
    }

    // Configurações globais do app
    match /app_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Regra mestre para outros documentos (opcional, por segurança)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
