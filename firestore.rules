rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AlphaBet League - Regras de Segurança Consolidadas
     */

    // Função de Administrador: Identificação direta por UID (Jardel)
    // Usamos o UID para garantir acesso instantâneo sem depender de propagação de token ou existência de documentos.
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "TquLV2ai1yRgfWPJHZGrHKifgc72" || 
        request.auth.token.email == "jardel@alphabet.com"
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- REGRA MESTRE PARA ADMINISTRADORES ---
    // Esta regra garante que o Jardel possa realizar QUALQUER operação (get, list, create, update, delete)
    // em QUALQUER documento ou consulta global (Collection Group).
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- REGRAS PARA USUÁRIOS COMUNS ---

    // Regras globais para apostas e placares (usadas em buscas de todos os jogadores)
    match /{path=**}/bets/{betId} {
      allow read: if request.auth != null && (
        isOwner(resource.data.userId) || 
        resource.data.isScoresHidden == false
      );
    }

    match /{path=**}/player_scores/{userId} {
      allow read: if request.auth != null && (
        isOwner(userId) || 
        resource.data.isScoresHidden == false
      );
    }

    // Regras de caminho específico para o perfil e dados do próprio usuário
    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      
      match /bets/{betId} {
        allow read, write: if isOwner(userId);
      }
      
      match /overall_stats {
        allow get, list: if isOwner(userId);
      }
    }

    // Dados públicos (Rodadas e Classificação)
    match /rounds/{roundId} {
      allow get, list: if request.auth != null;
      
      match /matches/{matchId} {
        allow get, list: if request.auth != null;
      }
      
      match /player_scores/{userId} {
        allow get, list: if isOwner(userId) || resource.data.isScoresHidden == false;
      }
    }

    match /app_settings/{docId} {
      allow get: if request.auth != null;
    }
    
    match /roles_admin/{userId} {
      allow get: if request.auth != null;
      // Permite que o primeiro admin se registre
      allow create: if request.auth != null && request.auth.token.email == "jardel@alphabet.com";
    }
  }
}