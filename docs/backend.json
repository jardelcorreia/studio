
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Representa um participante da AlphaBet League.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único do usuário."
        },
        "username": {
          "type": "string",
          "description": "Nome de exibição escolhido pelo usuário."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Indica se o usuário tem privilégios de administrador."
        },
        "photoUrl": {
          "type": "string",
          "description": "URL da foto de perfil armazenada no Firebase Storage."
        },
        "fcmTokens": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tokens de dispositivos para Push Notifications."
        },
        "dateCreated": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "username",
        "isAdmin"
      ]
    },
    "Round": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Round",
      "type": "object",
      "description": "Representa uma rodada específica do campeonato.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único da rodada (ex: round_1)."
        },
        "roundNumber": {
          "type": "number",
          "description": "O número sequencial da rodada."
        },
        "name": {
          "type": "string",
          "description": "Nome descritivo da rodada."
        },
        "isScoresHidden": {
          "type": "boolean",
          "description": "Indica se os palpites dos outros jogadores estão ocultos."
        },
        "matches": {
          "type": "array",
          "description": "Dados das partidas sobrescritos manualmente pelo administrador.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "homeScore": { "type": "number" },
              "awayScore": { "type": "number" },
              "status": { "type": "string" }
            }
          }
        },
        "dateCreated": {
          "type": "string",
          "format": "date-time"
        },
        "dateUpdated": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "roundNumber",
        "name",
        "isScoresHidden",
        "dateCreated",
        "dateUpdated"
      ]
    },
    "PlayerBet": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PlayerBet",
      "type": "object",
      "description": "Um palpite específico de placar para uma partida.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Formato: userId_matchIndex"
        },
        "userId": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "matchId": {
          "type": "string"
        },
        "homeScorePrediction": {
          "type": "number"
        },
        "awayScorePrediction": {
          "type": "number"
        },
        "dateSubmitted": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "username",
        "matchId",
        "homeScorePrediction",
        "awayScorePrediction",
        "dateSubmitted"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Perfis de usuário."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Marcador de privilégios de administrador."
        }
      },
      {
        "path": "/rounds/{roundId}",
        "definition": {
          "entityName": "Round",
          "schema": {
            "$ref": "#/backend/entities/Round"
          },
          "description": "Metadados da rodada e dados oficiais das partidas."
        }
      },
      {
        "path": "/rounds/{roundId}/bets/{betId}",
        "definition": {
          "entityName": "PlayerBet",
          "schema": {
            "$ref": "#/backend/entities/PlayerBet"
          },
          "description": "Apostas dentro de uma rodada específica."
        }
      }
    ]
  }
}
