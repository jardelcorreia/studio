
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a participant in the AlphaBet League.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "username": {
          "type": "string",
          "description": "The user's chosen display name or handle within the application."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Indicates if the user has administrative privileges."
        }
      },
      "required": [
        "id",
        "username",
        "isAdmin"
      ]
    },
    "Round": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Round",
      "type": "object",
      "description": "Represents a specific betting 'rodada' or matchday in the league.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Round entity."
        },
        "roundNumber": {
          "type": "number",
          "description": "The sequential number of the round."
        },
        "name": {
          "type": "string",
          "description": "The descriptive name of the round."
        },
        "isScoresHidden": {
          "type": "boolean",
          "description": "Indicates whether player scores are hidden."
        },
        "dateCreated": {
          "type": "string",
          "format": "date-time"
        },
        "dateUpdated": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "roundNumber",
        "name",
        "isScoresHidden",
        "dateCreated",
        "dateUpdated"
      ]
    },
    "PlayerBet": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PlayerBet",
      "type": "object",
      "description": "A specific score prediction for a match.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "matchId": {
          "type": "string"
        },
        "homeScorePrediction": {
          "type": "number"
        },
        "awayScorePrediction": {
          "type": "number"
        },
        "isScoresHidden": {
          "type": "boolean"
        },
        "dateSubmitted": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "username",
        "matchId",
        "homeScorePrediction",
        "awayScorePrediction",
        "dateSubmitted"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "User profiles."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Admin privileges marker."
        }
      },
      {
        "path": "/rounds/{roundId}",
        "definition": {
          "entityName": "Round",
          "schema": {
            "$ref": "#/backend/entities/Round"
          },
          "description": "Round metadata."
        }
      },
      {
        "path": "/rounds/{roundId}/bets/{betId}",
        "definition": {
          "entityName": "PlayerBet",
          "schema": {
            "$ref": "#/backend/entities/PlayerBet"
          },
          "description": "Bets within a round. betId format: userId_matchIdx"
        }
      }
    ],
    "reasoning": "Moving bets under rounds to avoid Collection Group index requirements and simplify real-time syncing."
  }
}
